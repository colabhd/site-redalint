---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { LANGUAGES, LOCALE_MAP, t, type Lang } from '~/i18n/translations';
import { localizedPath } from '~/utils/paths';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  image?: string;
  /** Path relative to /[lang]/ for hreflang alternates. Pass empty for home. */
  pathInLang?: string;
  /** Idiomas em que esta página existe (controla hreflang e o seletor de idioma). */
  availableLangs?: Lang[];
  noindex?: boolean;
}

const {
  title,
  description,
  lang,
  image,
  pathInLang = '',
  availableLangs = [...LANGUAGES],
  noindex = false,
} = Astro.props;

const siteTitle = t(lang, 'site.title');
const fullTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
const desc = description ?? t(lang, 'site.tagline');

const canonical = new URL(localizedPath(lang, pathInLang), Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL(`${import.meta.env.BASE_URL}og-default.png`.replace(/\/+/g, '/'), Astro.site).toString();
---

<!doctype html>
<html lang={LOCALE_MAP[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={canonical} />
    {
      availableLangs.map((l) => (
        <link
          rel="alternate"
          hreflang={LOCALE_MAP[l]}
          href={new URL(localizedPath(l, pathInLang), Astro.site).toString()}
        />
      ))
    }
    {
      availableLangs.length > 1 && (
        <link
          rel="alternate"
          hreflang="x-default"
          href={new URL(
            localizedPath(availableLangs.includes('pt') ? 'pt' : availableLangs[0], pathInLang),
            Astro.site,
          ).toString()}
        />
      )
    }

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={LOCALE_MAP[lang].replace('-', '_')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'redalintdark' : 'redalint');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'redalint');
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 btn btn-primary btn-sm">
      Ir para o conteúdo
    </a>
    <Header lang={lang} pathInLang={pathInLang} availableLangs={availableLangs} />
    <main id="main" class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
