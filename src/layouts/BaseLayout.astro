---
import '~/styles/global.css';
import Header from '~/components/Header.astro';
import Footer from '~/components/Footer.astro';
import { LANGUAGES, LOCALE_MAP, t, type Lang } from '~/i18n/translations';
import { localizedPath } from '~/utils/paths';

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  image?: string;
  /** Path relative to /[lang]/ for hreflang alternates. Pass empty for home. */
  pathInLang?: string;
  noindex?: boolean;
}

const { title, description, lang, image, pathInLang = '', noindex = false } = Astro.props;

const siteTitle = t(lang, 'site.title');
const fullTitle = title === siteTitle ? title : `${title} · ${siteTitle}`;
const desc = description ?? t(lang, 'site.tagline');

const canonical = new URL(localizedPath(lang, pathInLang), Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL(`${import.meta.env.BASE_URL}og-default.png`.replace(/\/+/g, '/'), Astro.site).toString();
---

<!doctype html>
<html lang={LOCALE_MAP[lang]}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <link rel="canonical" href={canonical} />
    {
      LANGUAGES.map((l) => (
        <link
          rel="alternate"
          hreflang={LOCALE_MAP[l]}
          href={new URL(localizedPath(l, pathInLang), Astro.site).toString()}
        />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(localizedPath('pt', pathInLang), Astro.site).toString()} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={LOCALE_MAP[lang].replace('-', '_')} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&family=Roboto+Slab:wght@400;600;700&display=swap"
    />

    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (prefersDark ? 'redalintdark' : 'redalint');
          document.documentElement.setAttribute('data-theme', theme);
        } catch (_) {
          document.documentElement.setAttribute('data-theme', 'redalint');
        }
      })();
    </script>
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "REDALINT",
      "url": Astro.site?.toString(),
      "logo": new URL(`${import.meta.env.BASE_URL}imagens/redalint-logo.svg`.replace(/\/+/g, '/'), Astro.site).toString(),
      "sameAs": [
        "https://github.com/colabhd/site-redalint",
        "https://acervo.redalint.org/"
      ]
    })}></script>
  </head>
  <body class="min-h-screen flex flex-col bg-base-100 text-base-content antialiased">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 btn btn-primary btn-sm">
      Ir para o conteúdo
    </a>
    <Header lang={lang} pathInLang={pathInLang} />
    <main id="main" data-pagefind-body class="flex-1">
      <slot />
    </main>
    <Footer lang={lang} />
  </body>
</html>
