---
import { t, type Lang } from '~/i18n/translations';
interface Props { lang: Lang }
const { lang } = Astro.props;
---

<button
  id="theme-toggle"
  class="btn btn-ghost btn-sm text-white hover:bg-white/10"
  aria-label={t(lang, 'nav.toggle_theme')}
>
  <svg id="icon-sun" class="hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4"/>
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"/>
  </svg>
  <svg id="icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    const sun = document.getElementById('icon-sun');
    const moon = document.getElementById('icon-moon');
    function reflect() {
      const t = document.documentElement.getAttribute('data-theme') || 'redalint';
      const dark = t === 'redalintdark';
      btn.setAttribute('aria-pressed', String(dark));
      if (sun) sun.classList.toggle('hidden', !dark);
      if (moon) moon.classList.toggle('hidden', dark);
    }
    reflect();
    btn.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme') || 'redalint';
      const next = current === 'redalintdark' ? 'redalint' : 'redalintdark';
      document.documentElement.setAttribute('data-theme', next);
      try { localStorage.setItem('theme', next); } catch (_) {}
      reflect();
    });
  })();
</script>
