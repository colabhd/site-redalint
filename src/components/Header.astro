---
import { t, LANGUAGES, type Lang } from '~/i18n/translations';
import { localizedPath, withBase } from '~/utils/paths';
import ThemeToggle from '~/components/ThemeToggle.astro';

interface Props {
  lang: Lang;
  pathInLang?: string;
}
const { lang, pathInLang = '' } = Astro.props;

const navItems = [
  { href: localizedPath(lang, ''), label: t(lang, 'nav.home') },
  { href: localizedPath(lang, 'institucional'), label: t(lang, 'nav.institucional') },
  { href: localizedPath(lang, 'noticias'), label: t(lang, 'nav.noticias') },
  { href: localizedPath(lang, 'publicacoes'), label: t(lang, 'nav.publicacoes') },
  { href: localizedPath(lang, 'pesquisas'), label: t(lang, 'nav.pesquisas') },
  { href: localizedPath(lang, 'equipe'), label: t(lang, 'nav.equipe') },
  { href: 'https://acervo.redalint.org/', label: t(lang, 'nav.acervo'), external: true },
];
---

<header class="sticky top-0 z-30 bg-base-100/90 backdrop-blur border-b border-base-300">
  <div class="container mx-auto px-4 flex items-center gap-4 h-16">
    <a href={localizedPath(lang, '')} class="font-bold text-lg tracking-tight text-primary">
      REDALINT
    </a>

    <nav class="hidden lg:flex items-center gap-1 ml-4 flex-1" aria-label="Principal">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="btn btn-ghost btn-sm font-normal"
            {...(item.external ? { rel: 'noopener', target: '_blank' } : {})}
          >
            {item.label}
            {item.external && <span aria-hidden="true" class="ml-1 text-xs">↗</span>}
          </a>
        ))
      }
    </nav>

    <div class="ml-auto flex items-center gap-2">
      <div class="dropdown dropdown-end">
        <button class="btn btn-ghost btn-sm" aria-label={t(lang, 'nav.language')}>
          {lang.toUpperCase()}
        </button>
        <ul class="dropdown-content menu bg-base-100 rounded-box shadow border border-base-300 mt-2 w-32 z-40">
          {
            LANGUAGES.map((l) => (
              <li>
                <a href={localizedPath(l, pathInLang)} aria-current={l === lang ? 'true' : undefined}>
                  {l === 'pt' ? 'Português' : 'Español'}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <ThemeToggle lang={lang} />

      <a href={localizedPath(lang, 'busca')} class="btn btn-ghost btn-sm" aria-label={t(lang, 'nav.search')}>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
      </a>

      <details class="dropdown dropdown-end lg:hidden">
        <summary class="btn btn-ghost btn-sm" aria-label="Menu">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="6" x2="21" y2="6"/>
            <line x1="3" y1="12" x2="21" y2="12"/>
            <line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </summary>
        <ul class="dropdown-content menu bg-base-100 rounded-box shadow border border-base-300 mt-2 w-56 z-40">
          {
            navItems.map((item) => (
              <li>
                <a href={item.href} {...(item.external ? { rel: 'noopener', target: '_blank' } : {})}>
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </details>
    </div>
  </div>
</header>
