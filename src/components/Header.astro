---
import { t, LANGUAGES, type Lang } from '~/i18n/translations';
import { localizedPath } from '~/utils/paths';
import ThemeToggle from '~/components/ThemeToggle.astro';

interface Props {
  lang: Lang;
  pathInLang?: string;
  /** Idiomas em que a página atual existe; demais idiomas levam à home. */
  availableLangs?: Lang[];
}
const { lang, pathInLang = '', availableLangs = [...LANGUAGES] } = Astro.props;

const navItems = [
  { href: localizedPath(lang, 'institucional'), label: t(lang, 'nav.institucional') },
  { href: localizedPath(lang, 'noticias'), label: t(lang, 'nav.noticias') },
  { href: localizedPath(lang, 'publicacoes'), label: t(lang, 'nav.publicacoes') },
  { href: localizedPath(lang, 'pesquisas'), label: t(lang, 'nav.pesquisas') },
  { href: localizedPath(lang, 'equipe'), label: t(lang, 'nav.equipe') },
  { href: 'https://acervo.redalint.org/', label: t(lang, 'nav.acervo'), external: true },
];
---

<header class="sticky top-0 z-30 shadow-sm">
  <div class="grid grid-cols-1 lg:grid-cols-[minmax(220px,25%)_1fr]">
    <!-- coluna do logo (branca) -->
    <div class="bg-base-100 flex items-center justify-center lg:justify-start px-6 py-3">
      <a href={localizedPath(lang, '')} class="block" aria-label="REDALINT — Início">
        <img
          src={`${import.meta.env.BASE_URL}imagens/redalint-wordmark.png`.replace(/\/+/g, '/')}
          alt="REDALINT"
          width="274"
          height="48"
          class="h-12 w-auto"
        />
      </a>
    </div>

    <!-- coluna do menu (gradiente índigo→roxo do site original) -->
    <div class="brand-gradient text-white">
      <div class="flex items-center gap-1 h-full px-4 lg:px-6 justify-end lg:justify-between">
        <nav class="hidden lg:flex items-center gap-1 overflow-x-auto" aria-label="Principal">
          {
            navItems.map((item) => (
              <a
                href={item.href}
                class="px-4 py-2 text-sm font-medium uppercase tracking-wide rounded hover:bg-white/10 hover:underline underline-offset-8 decoration-2"
                {...(item.external ? { rel: 'noopener', target: '_blank' } : {})}
              >
                {item.label}
                {item.external && <span aria-hidden="true" class="ml-1 text-xs opacity-80">↗</span>}
              </a>
            ))
          }
        </nav>

        <div class="flex items-center gap-1 ml-auto">
          <a
            href={localizedPath(lang, 'busca')}
            class="btn btn-ghost btn-sm text-white hover:bg-white/10"
            aria-label={t(lang, 'nav.search')}
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="11" cy="11" r="7"/>
              <line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </a>

          <div class="dropdown dropdown-end">
            <button
              class="btn btn-ghost btn-sm text-white hover:bg-white/10"
              aria-label={t(lang, 'nav.language')}
            >
              {lang.toUpperCase()}
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <ul class="dropdown-content menu bg-base-100 text-base-content rounded-box shadow border border-base-300 mt-2 w-36 z-40">
              {
                LANGUAGES.map((l) => (
                  <li>
                    <a
                      href={localizedPath(l, availableLangs.includes(l) ? pathInLang : '')}
                      aria-current={l === lang ? 'true' : undefined}
                    >
                      {l === 'pt' ? 'Português' : 'Español'}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <ThemeToggle lang={lang} />

          <details class="dropdown dropdown-end lg:hidden">
            <summary class="btn btn-ghost btn-sm text-white hover:bg-white/10" aria-label="Menu">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"/>
                <line x1="3" y1="12" x2="21" y2="12"/>
                <line x1="3" y1="18" x2="21" y2="18"/>
              </svg>
            </summary>
            <ul class="dropdown-content menu bg-base-100 text-base-content rounded-box shadow border border-base-300 mt-2 w-60 z-40">
              {
                navItems.map((item) => (
                  <li>
                    <a href={item.href} {...(item.external ? { rel: 'noopener', target: '_blank' } : {})}>
                      {item.label}
                    </a>
                  </li>
                ))
              }
            </ul>
          </details>
        </div>
      </div>
    </div>
  </div>
</header>
