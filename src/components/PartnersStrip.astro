---
import { t, type Lang } from '~/i18n/translations';

interface Partner { name: string; href: string; logo: string; }
const PARTNERS: Partner[] = [
  { name: 'CAPES', href: 'https://www.gov.br/capes/', logo: 'capes.svg' },
  { name: 'CNPq', href: 'https://www.gov.br/cnpq/', logo: 'cnpq.svg' },
  { name: 'FAPESP', href: 'https://fapesp.br/', logo: 'fapesp.svg' },
  { name: 'FAPERGS', href: 'https://fapergs.rs.gov.br/', logo: 'fapergs.svg' },
  { name: 'CLACSO', href: 'https://www.clacso.org/', logo: 'clacso.svg' },
  { name: 'UNESP', href: 'https://www.unesp.br/', logo: 'unesp.svg' },
  { name: 'UNCo', href: 'https://www.uncoma.edu.ar/', logo: 'unco.svg' },
];

interface Props { lang: Lang; variant?: 'home' | 'footer'; }
const { lang, variant = 'home' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<section class={variant === 'home' ? 'py-12 bg-base-200' : 'py-8 border-t border-white/10'}>
  <div class="container mx-auto px-4">
    {variant === 'home' && (
      <h2 class="section-title text-center text-xl text-base-content/70">{t(lang, 'home.partners_title')}</h2>
    )}
    <ul class={`${variant === 'home' ? 'mt-8' : 'mt-0'} flex flex-wrap items-center justify-center gap-8 md:gap-12 list-none p-0`}>
      {PARTNERS.map((p) => (
        <li>
          <a href={p.href} rel="noopener" target="_blank" aria-label={p.name} class="block opacity-70 hover:opacity-100 transition">
            <img
              src={`${base}/imagens/parceiros/${p.logo}`.replace(/\/+/g, '/')}
              alt={p.name}
              loading="lazy"
              decoding="async"
              class="h-10 md:h-12 w-auto"
              onerror={`this.outerHTML='<span class=\\'text-sm font-medium opacity-80\\'>'+this.alt+'</span>'`}
            />
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
