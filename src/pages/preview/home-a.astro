---
// PREVIEW — Opção A: "Mapa imersivo"
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import NoticiaCard from '~/components/NoticiaCard.astro';
import PartnersStrip from '~/components/PartnersStrip.astro';
import { t } from '~/i18n/translations';
import { localizedPath, assetPath } from '~/utils/paths';
import { entrySlug } from '~/utils/content';

const lang = 'pt' as const;
const latest = (await getCollection('noticias', (e) => e.data.lang === 'pt'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const mapImg = assetPath('/imagens/wp/mapa-america-latina02-768x937.png');

const stats = [
  { n: '2015', l: 'rede criada' },
  { n: '7', l: 'universidades' },
  { n: '3', l: 'países' },
  { n: '+200', l: 'publicações no acervo' },
];
const acessos = [
  { t: 'Acervo Digital', d: 'Mais de 200 publicações sobre internacionalização da educação superior.', href: 'https://acervo.redalint.org/', ext: true },
  { t: 'Revista REDALINT', d: 'Revista científica de acesso aberto, 8 números publicados.', href: localizedPath(lang, 'revista') },
  { t: 'Formação', d: 'Diplomatura em Gestão da Internacionalização Universitária.', href: localizedPath(lang, 'formacao') },
  { t: 'Pesquisas', d: 'Projetos e produção científica da rede.', href: localizedPath(lang, 'pesquisas') },
];
---

<BaseLayout lang={lang} title={t(lang, 'site.title')} description={t(lang, 'site.tagline')} pathInLang="" noindex>
  <!-- HERO imersivo -->
  <section class="relative overflow-hidden brand-gradient text-white">
    <img src={mapImg} alt="" aria-hidden="true" class="pointer-events-none absolute -right-10 top-1/2 -translate-y-1/2 h-[120%] w-auto opacity-25 hidden md:block" />
    <div class="container mx-auto px-4 py-24 md:py-32 relative">
      <div class="max-w-2xl">
        <p class="font-bold uppercase tracking-[0.2em] text-sm text-white/80">REDALINT</p>
        <h1 class="font-display text-4xl md:text-6xl font-bold mt-4 leading-[1.05] text-balance">
          Pensar a internacionalização desde a América Latina
        </h1>
        <p class="mt-6 text-lg md:text-xl text-white/90 text-balance">
          {t(lang, 'site.tagline')}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-lg bg-white text-primary border-none hover:bg-white/90" href={localizedPath(lang, 'institucional')}>
            {t(lang, 'home.cta_institucional')}
          </a>
          <a class="btn btn-lg btn-outline text-white border-white/60 hover:bg-white/10 hover:border-white" href="https://acervo.redalint.org/" rel="noopener" target="_blank">
            {t(lang, 'nav.acervo')} ↗
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAIXA DE NÚMEROS -->
  <section class="bg-base-100 border-b border-base-300">
    <div class="container mx-auto px-4 py-10 grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
      {stats.map((s) => (
        <div>
          <p class="font-display text-4xl md:text-5xl font-bold text-primary">{s.n}</p>
          <p class="mt-1 text-sm uppercase tracking-wide opacity-70">{s.l}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- ACESSO RÁPIDO -->
  <section class="bg-base-200 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {acessos.map((a) => (
          <a href={a.href} {...(a.ext ? { rel: 'noopener', target: '_blank' } : {})}
             class="group bg-base-100 rounded-box p-7 border border-base-300 hover:border-primary hover:shadow-lg transition-all flex flex-col">
            <span class="w-10 h-1.5 rounded-full bg-accent mb-5"></span>
            <h2 class="font-display text-xl font-bold text-primary">{a.t}{a.ext && <span class="opacity-60"> ↗</span>}</h2>
            <p class="mt-3 opacity-75 text-sm leading-relaxed flex-1">{a.d}</p>
            <span class="mt-5 text-primary font-medium text-sm group-hover:underline underline-offset-4">Acessar →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- QUEM SOMOS curto -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4 grid md:grid-cols-[1.2fr_1fr] gap-12 items-center">
      <div>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-primary">{t(lang, 'home.about_title')}</h2>
        <div class="section-divider mt-4"></div>
        <p class="mt-6 text-lg leading-relaxed opacity-80">{t(lang, 'home.about_body')}</p>
        <a class="btn btn-primary mt-7" href={localizedPath(lang, 'institucional')}>{t(lang, 'home.cta_institucional')}</a>
      </div>
      <img src={mapImg} alt="" aria-hidden="true" class="max-h-[360px] w-auto mx-auto" />
    </div>
  </section>

  <!-- NOTÍCIAS -->
  <section class="bg-base-200 py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="flex items-end justify-between flex-wrap gap-4">
        <div>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-primary">{t(lang, 'home.news_title')}</h2>
          <p class="mt-2 opacity-70">{t(lang, 'home.news_body')}</p>
        </div>
        <a class="btn btn-outline btn-primary" href={localizedPath(lang, 'noticias')}>{t(lang, 'home.news_more')}</a>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mt-10">
        {latest.map((n) => (
          <NoticiaCard lang={lang} slug={entrySlug(n)} title={n.data.title} date={n.data.date} excerpt={n.data.excerpt} image={n.data.image} />
        ))}
      </div>
    </div>
  </section>

  <PartnersStrip lang={lang} />
</BaseLayout>
