---
// PREVIEW (noindex) — layouts de logos das instituições para escolha
import BaseLayout from '~/layouts/BaseLayout.astro';
import { assetPath } from '~/utils/paths';

const unis = [
  { name: 'UNCo', logo: '/imagens/wp/UNCO-282x300.png' },
  { name: 'UNS', logo: '/imagens/wp/uns-300x196.jpg' },
  { name: 'UNSAM', logo: '/imagens/parceiros/unsam.png' },
  { name: 'UNESP', logo: '/imagens/wp/unesp.png' },
  { name: 'UCS', logo: '/imagens/parceiros/ucs.png' },
  { name: 'UFPel', logo: '/imagens/parceiros/ufpel.png' },
  { name: 'UFSC', logo: '/imagens/parceiros/ufsc.png' },
  { name: 'UEPA', logo: '/imagens/parceiros/uepa.png' },
  { name: 'UCN', logo: '/imagens/parceiros/ucn.png' },
  { name: 'UDP', logo: '/imagens/parceiros/udp.png' },
];

// órbita: posições num círculo
const BOX = 620; // tamanho do palco
const R = 250; // raio
const c = BOX / 2;
const orbit = unis.map((u, i) => {
  const a = (i / unis.length) * 2 * Math.PI - Math.PI / 2;
  return { ...u, x: c + R * Math.cos(a), y: c + R * Math.sin(a) };
});
const wordmark = assetPath('/imagens/redalint-wordmark.png');
---

<BaseLayout lang="pt" title="Prévia — logos" pathInLang="" noindex>
  <section class="container mx-auto px-4 py-12">
    <h1 class="font-display text-3xl font-bold text-primary">Prévia — instituições da rede</h1>
    <p class="opacity-70 mt-2">Duas opções de apresentação dos logos, com tamanhos uniformes.</p>

    <!-- OPÇÃO A: ÓRBITA -->
    <h2 class="section-title text-xl text-primary mt-12 mb-2">Opção A — REDALINT no centro, universidades ao redor</h2>
    <div class="bg-base-200 rounded-box p-6 overflow-hidden">
      <div class="relative mx-auto hidden md:block" style={`width:${BOX}px;height:${BOX}px`}>
        {/* linhas sutis até o centro */}
        <svg class="absolute inset-0 w-full h-full text-primary/15" aria-hidden="true">
          {orbit.map((u) => (
            <line x1={c} y1={c} x2={u.x} y2={u.y} stroke="currentColor" stroke-width="1" />
          ))}
        </svg>
        {orbit.map((u) => (
          <div
            class="absolute -translate-x-1/2 -translate-y-1/2 w-28 h-28 rounded-full bg-base-100 border border-base-300 shadow-sm flex items-center justify-center p-3"
            style={`left:${u.x}px;top:${u.y}px`}
            title={u.name}
          >
            <img src={assetPath(u.logo)} alt={u.name} class="max-w-[80%] max-h-[80%] object-contain" />
          </div>
        ))}
        {/* centro REDALINT */}
        <div
          class="absolute -translate-x-1/2 -translate-y-1/2 w-44 h-44 rounded-full bg-primary text-primary-content shadow-lg flex items-center justify-center p-6"
          style={`left:${c}px;top:${c}px`}
        >
          <img src={wordmark} alt="REDALINT" class="w-full object-contain brightness-0 invert" />
        </div>
      </div>

      {/* mobile: centro + grade */}
      <div class="md:hidden">
        <div class="mx-auto w-40 h-40 rounded-full bg-primary text-primary-content shadow flex items-center justify-center p-5 mb-6">
          <img src={wordmark} alt="REDALINT" class="w-full object-contain brightness-0 invert" />
        </div>
        <div class="grid grid-cols-3 gap-3">
          {unis.map((u) => (
            <div class="aspect-square rounded-box bg-base-100 border border-base-300 flex items-center justify-center p-3">
              <img src={assetPath(u.logo)} alt={u.name} class="max-w-[80%] max-h-[80%] object-contain" />
            </div>
          ))}
        </div>
      </div>
    </div>

    <!-- OPÇÃO B: GRADE UNIFORME -->
    <h2 class="section-title text-xl text-primary mt-16 mb-2">Opção B — grade de caixas uniformes</h2>
    <div class="bg-base-200 rounded-box p-8">
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-5 max-w-4xl mx-auto">
        {unis.map((u) => (
          <div class="aspect-[4/3] rounded-box bg-base-100 border border-base-300 flex items-center justify-center p-4" title={u.name}>
            <img src={assetPath(u.logo)} alt={u.name} class="max-w-[85%] max-h-[80%] object-contain" />
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
