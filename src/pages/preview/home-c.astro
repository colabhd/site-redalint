---
// PREVIEW — Opção C: "Minimalista editorial"
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { t } from '~/i18n/translations';
import { localizedPath, assetPath } from '~/utils/paths';
import { entrySlug } from '~/utils/content';

const lang = 'pt' as const;
const latest = (await getCollection('noticias', (e) => e.data.lang === 'pt'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
const fmt = (d: Date) => new Intl.DateTimeFormat('pt-BR', { dateStyle: 'long' }).format(d);

const links = [
  { t: 'Institucional', d: 'Quem somos, histórico e instituições da rede.', href: localizedPath(lang, 'institucional') },
  { t: 'Acervo Digital', d: 'Publicações latino-americanas sobre internacionalização.', href: 'https://acervo.redalint.org/', ext: true },
  { t: 'Revista REDALINT', d: 'Revista científica de acesso aberto.', href: localizedPath(lang, 'revista') },
  { t: 'Formação', d: 'Diplomatura em Gestão da Internacionalização.', href: localizedPath(lang, 'formacao') },
  { t: 'Pesquisas', d: 'Projetos e produção científica da rede.', href: localizedPath(lang, 'pesquisas') },
  { t: 'Equipe', d: 'Pesquisadores e gestores de 3 países.', href: localizedPath(lang, 'equipe') },
];
---

<BaseLayout lang={lang} title={t(lang, 'site.title')} description={t(lang, 'site.tagline')} pathInLang="" noindex>
  <!-- HERO tipográfico -->
  <section class="container mx-auto px-4 pt-24 pb-16 md:pt-36 md:pb-24 max-w-4xl">
    <p class="font-bold uppercase tracking-[0.25em] text-sm text-accent">REDALINT · desde 2015</p>
    <h1 class="font-display text-4xl md:text-6xl lg:text-7xl font-bold text-primary mt-6 leading-[1.05] text-balance">
      Rede de Pesquisadores e Gestores em Internacionalização da Educação Superior da América Latina
    </h1>
    <p class="mt-8 text-lg md:text-xl opacity-70 max-w-2xl">
      Um espaço crítico para pensar a internacionalização de modo horizontal, solidário e recíproco, a partir do Sul.
    </p>
    <div class="mt-10 flex flex-wrap gap-6 items-center">
      <a class="btn btn-primary btn-lg" href={localizedPath(lang, 'institucional')}>{t(lang, 'home.cta_institucional')}</a>
      <a class="link link-primary font-medium" href="https://acervo.redalint.org/" rel="noopener" target="_blank">Consultar o acervo ↗</a>
    </div>
  </section>

  <!-- NÚMEROS inline discreto -->
  <section class="border-y border-base-300">
    <div class="container mx-auto px-4 py-8 flex flex-wrap gap-x-12 gap-y-4 text-sm">
      <span><strong class="font-display text-lg text-primary">7</strong> universidades</span>
      <span><strong class="font-display text-lg text-primary">3</strong> países</span>
      <span><strong class="font-display text-lg text-primary">+200</strong> publicações no acervo</span>
      <span><strong class="font-display text-lg text-primary">8</strong> números da revista</span>
    </div>
  </section>

  <!-- EXPLORAR — lista editorial -->
  <section class="container mx-auto px-4 py-16 md:py-24 max-w-4xl">
    <h2 class="font-display text-2xl font-bold text-primary mb-2">Explorar</h2>
    <ul class="divide-y divide-base-300">
      {links.map((l) => (
        <li>
          <a href={l.href} {...(l.ext ? { rel: 'noopener', target: '_blank' } : {})}
             class="group flex items-baseline justify-between gap-6 py-6 hover:px-2 transition-all">
            <div>
              <h3 class="font-display text-xl md:text-2xl font-semibold group-hover:text-primary transition-colors">{l.t}{l.ext && <span class="opacity-50 text-base"> ↗</span>}</h3>
              <p class="mt-1 opacity-65">{l.d}</p>
            </div>
            <span class="text-2xl text-primary opacity-0 group-hover:opacity-100 transition-opacity">→</span>
          </a>
        </li>
      ))}
    </ul>
  </section>

  <!-- NOTÍCIAS minimal -->
  <section class="bg-base-200 py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="flex items-end justify-between mb-8">
        <h2 class="font-display text-2xl font-bold text-primary">{t(lang, 'home.news_title')}</h2>
        <a class="link link-primary text-sm font-medium" href={localizedPath(lang, 'noticias')}>{t(lang, 'home.news_more')} →</a>
      </div>
      <div class="space-y-px">
        {latest.map((n) => (
          <a href={localizedPath(lang, `noticias/${entrySlug(n)}`)} class="group flex flex-col md:flex-row gap-5 bg-base-100 p-6 hover:bg-base-100/60 transition-colors first:rounded-t-box last:rounded-b-box">
            {n.data.image && <img src={assetPath(n.data.image)} alt="" loading="lazy" class="w-full md:w-44 h-40 md:h-28 object-cover rounded-box shrink-0" />}
            <div>
              <time class="text-xs uppercase tracking-wide opacity-60">{fmt(n.data.date)}</time>
              <h3 class="font-display text-xl font-semibold mt-1 group-hover:text-primary transition-colors">{n.data.title}</h3>
              {n.data.excerpt && <p class="mt-2 opacity-70 text-sm line-clamp-2">{n.data.excerpt}</p>}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
