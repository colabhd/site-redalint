---
// PREVIEW — Opção B: "Portal de cards"
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import NoticiaCard from '~/components/NoticiaCard.astro';
import PartnersStrip from '~/components/PartnersStrip.astro';
import { t } from '~/i18n/translations';
import { localizedPath, assetPath } from '~/utils/paths';
import { entrySlug } from '~/utils/content';

const lang = 'pt' as const;
const latest = (await getCollection('noticias', (e) => e.data.lang === 'pt'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
const wordmark = assetPath('/imagens/redalint-wordmark.png');
const mapImg = assetPath('/imagens/wp/mapa-america-latina02-768x937.png');

const features = [
  { t: 'Acervo Digital', d: '+200 publicações latino-americanas sobre internacionalização.', href: 'https://acervo.redalint.org/', ext: true, cls: 'bg-primary text-primary-content', span: 'lg:col-span-2 lg:row-span-2' },
  { t: 'Revista REDALINT', d: 'Acesso aberto · 8 números.', href: localizedPath(lang, 'revista'), cls: 'bg-base-100 border border-base-300' },
  { t: 'Formação', d: 'Diplomatura latino-americana.', href: localizedPath(lang, 'formacao'), cls: 'bg-base-100 border border-base-300' },
  { t: 'Pesquisas', d: 'Projetos e produção da rede.', href: localizedPath(lang, 'pesquisas'), cls: 'bg-accent text-accent-content' },
  { t: 'Equipe', d: '13 pesquisadores/as.', href: localizedPath(lang, 'equipe'), cls: 'bg-base-100 border border-base-300' },
];
---

<BaseLayout lang={lang} title={t(lang, 'site.title')} description={t(lang, 'site.tagline')} pathInLang="" noindex>
  <!-- HERO claro com wordmark -->
  <section class="bg-base-100">
    <div class="container mx-auto px-4 pt-16 pb-12 md:pt-24 md:pb-16 text-center max-w-3xl">
      <img src={wordmark} alt="REDALINT" width="420" height="74" class="h-16 md:h-20 w-auto mx-auto" />
      <p class="mt-7 text-lg md:text-xl opacity-80 text-balance">{t(lang, 'site.tagline')}</p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a class="btn btn-primary" href={localizedPath(lang, 'institucional')}>{t(lang, 'home.cta_institucional')}</a>
        <a class="btn btn-ghost" href={localizedPath(lang, 'busca')}>Buscar no site</a>
      </div>
    </div>
  </section>

  <!-- MOSAICO DE CARDS -->
  <section class="container mx-auto px-4 pb-16 md:pb-20">
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 auto-rows-fr gap-5">
      {features.map((f) => (
        <a href={f.href} {...(f.ext ? { rel: 'noopener', target: '_blank' } : {})}
           class={`${f.cls} ${f.span ?? ''} rounded-box p-7 flex flex-col justify-between hover:shadow-xl hover:-translate-y-0.5 transition-all min-h-44`}>
          <div>
            <h2 class="font-display text-2xl font-bold">{f.t}{f.ext && <span class="opacity-70"> ↗</span>}</h2>
            <p class="mt-3 opacity-80 leading-relaxed">{f.d}</p>
          </div>
          <span class="mt-6 font-medium">Acessar →</span>
        </a>
      ))}
    </div>
  </section>

  <!-- QUEM SOMOS faixa -->
  <section class="brand-gradient text-white py-16 md:py-20">
    <div class="container mx-auto px-4 grid md:grid-cols-[1fr_1.3fr] gap-10 items-center">
      <img src={mapImg} alt="" aria-hidden="true" class="max-h-[320px] w-auto mx-auto bg-white/95 rounded-box p-4" />
      <div>
        <h2 class="font-display text-3xl md:text-4xl font-bold">{t(lang, 'home.about_title')}</h2>
        <div class="h-1 w-16 bg-accent rounded-full mt-4"></div>
        <p class="mt-6 text-lg leading-relaxed text-white/90">{t(lang, 'home.about_body')}</p>
        <a class="btn bg-white text-primary border-none hover:bg-white/90 mt-7" href={localizedPath(lang, 'institucional')}>{t(lang, 'home.cta_institucional')}</a>
      </div>
    </div>
  </section>

  <!-- NOTÍCIAS -->
  <section class="py-16 md:py-20">
    <div class="container mx-auto px-4">
      <div class="text-center">
        <h2 class="font-display text-3xl md:text-4xl font-bold text-primary">{t(lang, 'home.news_title')}</h2>
        <p class="mt-2 opacity-70">{t(lang, 'home.news_body')}</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mt-10">
        {latest.map((n) => (
          <NoticiaCard lang={lang} slug={entrySlug(n)} title={n.data.title} date={n.data.date} excerpt={n.data.excerpt} image={n.data.image} />
        ))}
      </div>
      <div class="text-center mt-10">
        <a class="btn btn-primary" href={localizedPath(lang, 'noticias')}>{t(lang, 'home.news_more')}</a>
      </div>
    </div>
  </section>

  <PartnersStrip lang={lang} />
</BaseLayout>
