---
import { getCollection } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import SectionBand from '~/components/SectionBand.astro';
import NoticiaCard from '~/components/NoticiaCard.astro';
import PartnersStrip from '~/components/PartnersStrip.astro';
import { LANGUAGES, t, type Lang } from '~/i18n/translations';
import { localizedPath } from '~/utils/paths';

export function getStaticPaths() {
  return LANGUAGES.map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;

const allNews = await getCollection('noticias', (e) => e.data.lang === lang);
const latest = allNews
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const mapImg = `${import.meta.env.BASE_URL}imagens/wp/mapa-america-latina02-768x937.png`.replace(/\/+/g, '/');
---

<BaseLayout
  lang={lang}
  title={t(lang, 'site.title')}
  description={t(lang, 'site.tagline')}
  pathInLang=""
>
  <!-- HERO -->
  <section class="relative overflow-hidden bg-base-200">
    <div class="container mx-auto px-4 py-20 md:py-28 grid md:grid-cols-2 gap-10 items-center">
      <div>
        <p class="text-accent font-bold uppercase tracking-widest text-sm">REDALINT</p>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-bold text-primary mt-3 leading-tight text-balance">
          {t(lang, 'home.welcome')}
        </h1>
        <p class="mt-6 text-lg opacity-80 text-balance">
          {t(lang, 'site.tagline')}
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a class="btn btn-primary" href={localizedPath(lang, 'institucional')}>
            {t(lang, 'common.know_more')}
          </a>
          <a class="btn btn-outline btn-primary" href="https://acervo.redalint.org/" rel="noopener" target="_blank">
            {t(lang, 'nav.acervo')} ↗
          </a>
        </div>
      </div>
      <div class="hidden md:flex justify-center">
        <img
          src={mapImg}
          alt=""
          aria-hidden="true"
          class="max-h-[420px] w-auto opacity-90"
          loading="eager"
          decoding="async"
          onerror="this.style.display='none'"
        />
      </div>
    </div>
  </section>

  <!-- QUEM SOMOS -->
  <SectionBand variant="primary">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-title text-3xl md:text-4xl">{t(lang, 'home.about_title')}</h2>
      <div class="section-divider mx-auto mt-4"></div>
      <p class="mt-6 text-lg leading-relaxed opacity-95">
        {t(lang, 'home.about_body')}
      </p>
      <div class="mt-8">
        <a class="btn bg-base-100 text-primary border-none hover:bg-base-200" href={localizedPath(lang, 'institucional')}>
          {t(lang, 'common.know_more')}
        </a>
      </div>
    </div>
  </SectionBand>

  <!-- PROJETOS & PESQUISAS / PUBLICAÇÕES -->
  <SectionBand>
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div>
        <h2 class="section-title text-3xl text-primary">{t(lang, 'home.research_title')}</h2>
        <div class="section-divider mt-3"></div>
        <p class="mt-5 opacity-80 text-lg">{t(lang, 'home.research_body')}</p>
        <a class="btn btn-primary mt-6" href={localizedPath(lang, 'pesquisas')}>
          {t(lang, 'common.know_more')}
        </a>
      </div>
      <div class="bg-base-200 rounded-box aspect-[4/3] flex items-center justify-center">
        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-primary/40" aria-hidden="true">
          <path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/>
          <rect x="9" y="3" width="6" height="4" rx="1"/>
          <path d="M9 12h6M9 16h6"/>
        </svg>
      </div>
    </div>
  </SectionBand>

  <SectionBand>
    <div class="grid md:grid-cols-2 gap-10 items-center">
      <div class="md:order-2">
        <h2 class="section-title text-3xl text-primary">{t(lang, 'home.publications_title')}</h2>
        <div class="section-divider mt-3"></div>
        <p class="mt-5 opacity-80 text-lg">{t(lang, 'home.publications_body')}</p>
        <a class="btn btn-primary mt-6" href={localizedPath(lang, 'publicacoes')}>
          {t(lang, 'common.know_more')}
        </a>
      </div>
      <div class="md:order-1 bg-base-200 rounded-box aspect-[4/3] flex items-center justify-center">
        <svg width="120" height="120" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" class="text-primary/40" aria-hidden="true">
          <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
          <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
        </svg>
      </div>
    </div>
  </SectionBand>

  <!-- INICIATIVAS -->
  <SectionBand variant="dark">
    <div class="text-center">
      <h2 class="section-title text-3xl md:text-4xl">{t(lang, 'home.initiatives_title')}</h2>
      <div class="section-divider mx-auto mt-4"></div>
    </div>
    <div class="grid md:grid-cols-2 gap-8 mt-12 max-w-5xl mx-auto">
      <article class="border border-white/10 rounded-box p-8 text-center hover:border-accent/60 transition-colors">
        <div class="mx-auto w-16 h-16 rounded-full bg-accent/15 flex items-center justify-center text-accent">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/>
            <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>
          </svg>
        </div>
        <h3 class="section-title text-xl mt-5">{t(lang, 'home.initiative_journal')}</h3>
        <p class="opacity-80 mt-3">{t(lang, 'home.initiative_journal_body')}</p>
        <a class="btn btn-primary mt-6" href="http://revele.uncoma.edu.ar/htdoc/revele/index.php/redalint/index" rel="noopener" target="_blank">
          {t(lang, 'common.know_more')} ↗
        </a>
      </article>
      <article class="border border-white/10 rounded-box p-8 text-center hover:border-accent/60 transition-colors">
        <div class="mx-auto w-16 h-16 rounded-full bg-accent/15 flex items-center justify-center text-accent">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 7v13h18V7"/>
            <path d="M3 7l9-4 9 4"/>
            <path d="M9 21V12h6v9"/>
          </svg>
        </div>
        <h3 class="section-title text-xl mt-5">{t(lang, 'home.initiative_archive')}</h3>
        <p class="opacity-80 mt-3">{t(lang, 'home.initiative_archive_body')}</p>
        <a class="btn btn-primary mt-6" href="https://acervo.redalint.org/" rel="noopener" target="_blank">
          {t(lang, 'common.know_more')} ↗
        </a>
      </article>
    </div>
  </SectionBand>

  <!-- NOTÍCIAS -->
  <SectionBand>
    <div class="text-center">
      <h2 class="section-title text-3xl md:text-4xl text-primary">{t(lang, 'home.news_title')}</h2>
      <div class="section-divider mx-auto mt-4"></div>
      <p class="mt-4 opacity-80">{t(lang, 'home.news_body')}</p>
    </div>

    {latest.length === 0 ? (
      <p class="text-center opacity-70 mt-10">{t(lang, 'news.empty')}</p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 mt-12">
        {latest.map((n) => (
          <NoticiaCard
            lang={lang}
            slug={n.data.slug ?? n.id}
            title={n.data.title}
            date={n.data.date}
            excerpt={n.data.excerpt}
            image={n.data.image}
          />
        ))}
      </div>
    )}

    <div class="text-center mt-10">
      <a class="btn btn-primary" href={localizedPath(lang, 'noticias')}>
        {t(lang, 'home.news_more')}
      </a>
    </div>
  </SectionBand>

  <PartnersStrip lang={lang} variant="home" />

  <!-- EQUIPE -->
  <SectionBand variant="primary">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="section-title text-3xl md:text-4xl">{t(lang, 'home.team_title')}</h2>
      <div class="section-divider mx-auto mt-4"></div>
      <p class="mt-6 text-lg opacity-95">{t(lang, 'home.team_body')}</p>
      <a class="btn bg-base-100 text-primary border-none hover:bg-base-200 mt-8" href={localizedPath(lang, 'equipe')}>
        {t(lang, 'common.know_more')}
      </a>
    </div>
  </SectionBand>
</BaseLayout>
