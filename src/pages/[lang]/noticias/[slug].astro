---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { LOCALE_MAP, t, type Lang } from '~/i18n/translations';
import { assetPath, localizedPath } from '~/utils/paths';
import { entrySlug } from '~/utils/content';

export async function getStaticPaths() {
  const entries = await getCollection('noticias');
  return entries.map((entry) => ({
    params: { lang: entry.data.lang, slug: entrySlug(entry) },
    props: {
      entry,
      availableLangs: entries
        .filter((e) => entrySlug(e) === entrySlug(entry))
        .map((e) => e.data.lang),
    },
  }));
}

const { entry, availableLangs } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
const date = new Intl.DateTimeFormat(LOCALE_MAP[lang], { dateStyle: 'long' }).format(entry.data.date);
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.excerpt}
  image={entry.data.image && assetPath(entry.data.image)}
  pathInLang={`noticias/${entrySlug(entry)}`}
  availableLangs={availableLangs}
>
  <article class="container mx-auto px-4 py-12 max-w-3xl">
    <p class="opacity-70 text-sm">
      <a href={localizedPath(lang, 'noticias')} class="link link-hover">← {t(lang, 'news.title')}</a>
    </p>
    <h1 class="text-3xl md:text-4xl font-bold mt-3">{entry.data.title}</h1>
    <p class="opacity-70 mt-2 text-sm">
      <time datetime={entry.data.date.toISOString()}>{t(lang, 'news.published_on')} {date}</time>
      {entry.data.author && <> · {entry.data.author}</>}
    </p>

    {entry.data.image && (
      <img src={assetPath(entry.data.image)} alt="" class="rounded-lg my-8 w-full" loading="lazy" decoding="async" />
    )}

    <div class="prose max-w-none mt-8 dark:prose-invert">
      <Content />
    </div>
  </article>
</BaseLayout>
