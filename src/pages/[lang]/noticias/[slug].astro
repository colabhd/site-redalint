---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import EditOnGitHub from '~/components/EditOnGitHub.astro';
import { LOCALE_MAP, t, type Lang } from '~/i18n/translations';
import { assetPath, localizedPath } from '~/utils/paths';
import { entrySlug } from '~/utils/content';

export async function getStaticPaths() {
  const entries = await getCollection('noticias');
  return entries.map((entry) => ({
    params: { lang: entry.data.lang, slug: entrySlug(entry) },
    props: {
      entry,
      availableLangs: entries
        .filter((e) => entrySlug(e) === entrySlug(entry))
        .map((e) => e.data.lang),
    },
  }));
}

const { entry, availableLangs } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
const date = new Intl.DateTimeFormat(LOCALE_MAP[lang], { dateStyle: 'long' }).format(entry.data.date);
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.excerpt}
  image={entry.data.image && assetPath(entry.data.image)}
  pathInLang={`noticias/${entrySlug(entry)}`}
  availableLangs={availableLangs}
>
  <article class="container mx-auto px-4 py-12 max-w-3xl">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'NewsArticle',
        headline: entry.data.title,
        datePublished: entry.data.date.toISOString(),
        inLanguage: LOCALE_MAP[lang],
        author: { '@type': 'Organization', name: entry.data.author ?? 'REDALINT' },
        publisher: { '@type': 'Organization', name: 'REDALINT' },
        ...(entry.data.image && {
          image: new URL(assetPath(entry.data.image), Astro.site).toString(),
        }),
        mainEntityOfPage: new URL(
          localizedPath(lang, `noticias/${entrySlug(entry)}`),
          Astro.site,
        ).toString(),
      })}
    />
    <Breadcrumbs
      lang={lang}
      trail={[
        { label: t(lang, 'news.title'), href: localizedPath(lang, 'noticias') },
        { label: entry.data.title },
      ]}
    />
    <h1 class="text-3xl md:text-4xl font-bold mt-3">{entry.data.title}</h1>
    <p class="opacity-70 mt-2 text-sm">
      <time datetime={entry.data.date.toISOString()}>{t(lang, 'news.published_on')} {date}</time>
      {entry.data.author && <> · {entry.data.author}</>}
    </p>

    {entry.data.image && (
      <img src={assetPath(entry.data.image)} alt="" class="rounded-lg my-8 w-full" loading="lazy" decoding="async" />
    )}

    <div class="prose max-w-none mt-8">
      <Content />
    </div>
    <EditOnGitHub lang={lang} collection="noticias" slug={entrySlug(entry)} />
  </article>
</BaseLayout>
