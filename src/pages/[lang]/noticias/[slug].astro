---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import { LOCALE_MAP, t, type Lang } from '~/i18n/translations';
import { localizedPath } from '~/utils/paths';

export async function getStaticPaths() {
  const entries = await getCollection('noticias');
  return entries.map((entry) => ({
    params: { lang: entry.data.lang, slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
const date = new Intl.DateTimeFormat(LOCALE_MAP[lang], { dateStyle: 'long' }).format(entry.data.date);
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.excerpt}
  image={entry.data.image}
  pathInLang={`noticias/${entry.data.slug ?? entry.id}`}
>
  <article class="container mx-auto px-4 py-12 max-w-3xl">
    <Breadcrumbs lang={lang} trail={[
      { label: t(lang, 'news.title'), href: localizedPath(lang, 'noticias') },
      { label: entry.data.title },
    ]} />
    <h1 class="text-3xl md:text-4xl font-bold mt-3">{entry.data.title}</h1>
    <p class="opacity-70 mt-2 text-sm">
      <time datetime={entry.data.date.toISOString()}>{t(lang, 'news.published_on')} {date}</time>
      {entry.data.author && <> · {entry.data.author}</>}
    </p>

    {entry.data.image && (
      <img src={entry.data.image} alt="" class="rounded-lg my-8 w-full" loading="lazy" decoding="async" />
    )}

    <div class="prose max-w-none mt-8 dark:prose-invert">
      <Content />
    </div>
  </article>
</BaseLayout>
