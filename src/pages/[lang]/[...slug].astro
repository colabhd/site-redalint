---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import type { Lang } from '~/i18n/translations';
import { assetPath } from '~/utils/paths';
import { entrySlug } from '~/utils/content';

export async function getStaticPaths() {
  const entries = await getCollection('paginas');
  return entries.map((entry) => ({
    params: { lang: entry.data.lang, slug: entrySlug(entry) },
    props: {
      entry,
      availableLangs: entries
        .filter((e) => entrySlug(e) === entrySlug(entry))
        .map((e) => e.data.lang),
    },
  }));
}

const { entry, availableLangs } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
const slug = entrySlug(entry);
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.hero && assetPath(entry.data.hero)}
  pathInLang={slug}
  availableLangs={availableLangs}
>
  <article class="container mx-auto px-4 py-12 max-w-3xl">
    <h1 class="text-3xl md:text-4xl font-bold">{entry.data.title}</h1>
    {entry.data.description && <p class="opacity-80 mt-3 text-lg">{entry.data.description}</p>}
    <div class="prose max-w-none mt-8 dark:prose-invert">
      <Content />
    </div>
  </article>
</BaseLayout>
