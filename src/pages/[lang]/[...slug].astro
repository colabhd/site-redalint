---
import { getCollection, render } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import Breadcrumbs from '~/components/Breadcrumbs.astro';
import EditOnGitHub from '~/components/EditOnGitHub.astro';
import type { Lang } from '~/i18n/translations';

export async function getStaticPaths() {
  const entries = await getCollection('paginas');
  return entries.map((entry) => ({
    params: { lang: entry.data.lang, slug: entry.data.slug ?? entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const lang = entry.data.lang as Lang;
const { Content } = await render(entry);
const slug = entry.data.slug ?? entry.id;
---

<BaseLayout
  lang={lang}
  title={entry.data.title}
  description={entry.data.description}
  image={entry.data.hero}
  pathInLang={slug}
>
  <article class="container mx-auto px-4 py-12 max-w-3xl">
    <Breadcrumbs lang={lang} trail={[{ label: entry.data.title }]} />
    <h1 class="text-3xl md:text-4xl font-bold">{entry.data.title}</h1>
    {entry.data.description && <p class="opacity-80 mt-3 text-lg">{entry.data.description}</p>}
    <div class="prose max-w-none mt-8 dark:prose-invert">
      <Content />
    </div>
    <EditOnGitHub collection="paginas" lang={lang} slug={slug} />
  </article>
</BaseLayout>
